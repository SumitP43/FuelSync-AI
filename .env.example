# FuelSync-AI Environment Configuration
# Copy this file to .env and update with your values

# Application
APP_NAME=FuelSync-AI
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# Security - CHANGE THIS IN PRODUCTION
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql://fuelsync:fuelsync_password@localhost:5432/fuelsync_db

# Redis (optional caching)
REDIS_URL=redis://localhost:6379/0

# External APIs (optional)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# CORS Origins (JSON array format)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://127.0.0.1:8080"]

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
